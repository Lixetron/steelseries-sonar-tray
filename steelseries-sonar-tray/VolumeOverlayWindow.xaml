<Window x:Class="SteelSeries.SonarTray.VolumeOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Volume Overlay"
        Width="248"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        ResizeMode="NoResize"
        IsHitTestVisible="False"
        Opacity="1">
    <Border x:Name="OverlayRoot"
            Opacity="0"
            Background="#E6161616"
            BorderBrush="#44FFFFFF"
            BorderThickness="1"
            CornerRadius="10"
            Padding="12"
            SnapsToDevicePixels="True"
            UseLayoutRounding="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="ChannelNameText"
                       Grid.Row="0"
                       Grid.Column="1"
                       Foreground="#B8B8B8"
                       FontSize="10"
                       Margin="0,0,0,4"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"/>
            <TextBlock x:Name="VolumeIconText"
                       Grid.Row="0"
                       Grid.RowSpan="2"
                       Grid.Column="0"
                       Text="&#xE767;"
                       FontFamily="Segoe MDL2 Assets"
                       FontSize="14"
                       Foreground="#FFFFFF"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>
            <Border x:Name="TrackHost"
                    Grid.Row="1"
                    Grid.Column="1"
                    Height="3"
                    CornerRadius="1.5"
                    Background="#44FFFFFF"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0">
                <Border x:Name="VolumeFill"
                        HorizontalAlignment="Left"
                        Width="0"
                        CornerRadius="1.5"
                        Background="#FFFFFF"/>
            </Border>
            <TextBlock x:Name="VolumeValueText"
                       Grid.Row="0"
                       Grid.RowSpan="2"
                       Grid.Column="2"
                       Text="0%"
                       Foreground="#FFFFFF"
                       FontSize="11"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       MinWidth="30"
                       TextAlignment="Right"/>
        </Grid>
    </Border>
</Window>
